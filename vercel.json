{
  "name": "malik-family-care-clinic",
  "version": "1.0.0",
  "description": "Complete Hospital Management System",
  "scripts": {
    "dev": "concurrently -n FRONTEND,BACKEND -c cyan,magenta \"npm run dev:front\" \"npm run dev:back\"",
    "dev:front": "vite --port 3000 --host",
    "dev:back": "cd backend && npm run dev",
    "build": "npm run build:front && npm run build:back",
    "build:front": "vite build",
    "build:back": "cd backend && npm run build",
    "start": "cd backend && npm start",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "lucide-react": "^0.548.0",
    "recharts": "^3.6.0",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "jsbarcode": "^3.12.3",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "tailwindcss": "^4.1.16",
    "@tailwindcss/postcss": "^4.1.16",
    "postcss": "^8.5.6",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0"
  }
}
